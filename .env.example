# Server Port (default: 5001)
PORT=5001

# Privy App Credentials (for embedded server wallets)
PRIVY_APP_ID=YOUR_PRIVY_APP_ID
PRIVY_APP_SECRET=YOUR_PRIVY_APP_SECRET

# Agent Private Key (the registered agent wallet)
# If left blank, Vouch will dynamically generate a test agent wallet at startup
# and print the AgentBook CLI registration instructions.
AGENT_PRIVATE_KEY=0x...

# Demo Mock Mode for AgentBook (true/false)
# If set to true, requests will gracefully bypass live World ID verification checks
# and use simulated humanIds if the agent is not registered in the AgentBook contract yet.
MOCK_AGENTBOOK=true
