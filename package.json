{
  "name": "eth-global-nyc-2026",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently --kill-others \"nodemon --watch server --ext ts --exec \\\"bun run server/index.ts\\\"\" \"vite\"",
    "build:server": "tsc -p server/tsconfig.json",
    "build:frontend": "tsc -p tsconfig.json && vite build",
    "build": "tsc -p tsconfig.json && vite build && tsc -p server/tsconfig.json",
    "start": "node dist/server/index.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "deploy": "git push origin main && git push heroku main",
    "push": "bun run deploy",
    "heroku-postbuild": "tsc -p tsconfig.json && vite build && tsc -p server/tsconfig.json && rm -rf src public server tsconfig.json vite.config.ts eslint.config.js drizzle.config.ts"
  },
  "dependencies": {
    "@privy-io/node": "^0.21.0",
    "@worldcoin/agentkit": "^0.2.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "ethers": "^6.16.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "postgres": "^3.4.9",
    "viem": "^2.52.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@privy-io/react-auth": "^3.30.0",
    "@solana-program/compute-budget": "^0.15.0",
    "@solana-program/memo": "^0.11.1",
    "@solana-program/system": "^0.12.2",
    "@solana-program/token": "^0.13.0",
    "@solana-program/token-2022": "^0.11.0",
    "@solana/kit": "^6.9.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^6.0.2",
    "@types/node": "^24.12.3",
    "@types/node-fetch": "^2.6.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "lucide-react": "^1.18.0",
    "nodemon": "^3.1.14",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
